<!DOCTYPE html>
<html>
    <head>
        <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;700&display=swap" rel="stylesheet">
        <link href="https://fonts.googleapis.com/css2?family=Exo+2:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
        <title>Scout Engine</title>
        <style>
            body {
                margin: 0;
                height: 100vh;
                display: flex;
                justify-content: center;
                align-items: center;
                
                /*background color for if the images fail*/
                background-color: #000;

                /* Background settings to make the images look good */
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;

                /* Define the images as variables so they stay in memory to not be lost*/
                --image-1: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('/images/stadium.jpeg');
                --image-2: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('/images/basketball.jpeg');

                /*Gives browser an image to show when opening webpage and while the animation loads in*/
                background-image: var(--image-1);
                
                /* This links to the animation we define below */
                animation: backgroundFade 10s infinite alternate ease-in-out; 
            }

            @keyframes backgroundFade {
                0% {
                    background-image: var(--image-1);
                }
                100% {
                    background-image: var(--image-2);
                }
            }
            .main-content h1 {
                font-family: 'Bebas Neue', sans-serif;
                font-size: 5rem; 
                letter-spacing: 2px; 

                /* Makes background of text identical */
                /* Will have cookie cutter effect */
                background-size: cover;
                background-position: center;
                background-attachment: fixed; /* This is the alignment part */

                /* Clip the background to the text */
                -webkit-background-clip: text;
                background-clip: text;
                color: transparent;

                filter: brightness(1.2);

                /* Use the same animation as the body */
                animation: backgroundFade 10s infinite alternate ease-in-out; 

                /* outline for text sharpness */
                -webkit-text-stroke: 1px rgba(255, 255, 255, 0.1);
            }
            .main-content p,a {
                font-family: 'Exo 2', sans-serif;
            }
            .main-content {
                color: rgba(255, 255, 255, 0.95);
                text-align: center;
                padding: 40px;
                background-color: rgba(255, 64, 0, 0.12); 
                border-radius: 12px;
                /* Adds a "floating" effect and makes glass effect better*/
                box-shadow: 0 10px 50px rgba(0, 0, 0, 0.65),
                            inset 0 0 15px rgba(255, 201, 183, 0.23); 
                border: 2px solid rgba(255, 201, 183, 0.12);
                backdrop-filter : blur(8px)
            }
            a {
                display: inline-block;
                margin-top: 20px;
                padding: 12px 24px;
                background-color: #620505;
                color: white;
                text-decoration: none;   
                font-weight: bold;
                border-radius: 6px;
                text-transform: uppercase;
                transition: background 0.3s; 
            }

            a:hover {
                background-color: #450101; /* Darkens slightly when you point at it */
            }
        </style>
    </head>
    <body>
        <div style="display:none;">
            <img src="/images/stadium.jpeg">
            <img src="/images/basketball.jpeg">
        </div>
        <div class="main-content">
            <h1>AI Scout Engine</h1>
            <p>Advanced Player Analysis and Engangement Generation</p>
            
            <a href="/scout">Start Batch Scout</a>
        </div>
    </body>
</html>