<!DOCTYPE html>
<html>
    <head>
        <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;700&display=swap" rel="stylesheet">
        <link href="https://fonts.googleapis.com/css2?family=Exo+2:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
        <title>Scout Engine</title>
        <style>
            body {
                margin: 0;
                height: 100vh;
                display: flex;
                justify-content: center;
                align-items: center;
                
                /*background color for if the images fail*/
                background-color: #000;

                overflow: hidden;
                position: relative;
            }

            /* bottom layer photo*/
            body::before {
                content: "";
                position: absolute;
                top: 0; left: 0; width: 100%; height: 100%;
                z-index: -2;
                background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), 
                            url('/images/stadium.jpeg') center/cover no-repeat;
            }

            /* top layer photo, will fade out and in */
            body::after {
                content: "";
                position: absolute;
                top: 0; left: 0; width: 100%; height: 100%;
                z-index: -1;
                background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), 
                            url('/images/basketball.jpeg') center/cover no-repeat;
                animation: smoothFade 15s infinite alternate ease-in-out;
                will-change: opacity; /* Tells the browser to prepare the GPU */
            }

            @keyframes smoothFade {
                0% { opacity: 0; }
                100% { opacity: 1; }
            }
            .main-content h1 {
                font-family: 'Bebas Neue', sans-serif;
                font-size: 5rem; 
                letter-spacing: 2px; 
                margin: 0;
                position: relative;

                /* makes the text transparent */
                -webkit-background-clip: text; 
                background-clip: text;
                color: transparent;

                /* base layer image */
                background-image: linear-gradient(rgba(0,0,0,0.2), rgba(0,0,0,0.2)), 
                      url('/images/stadium.jpeg');

                /* Makes background of text identical */
                /* Will have cookie cutter effect */
                background-size: cover;
                background-position: center;
                /*This is the alignment with the body background */
                background-attachment: fixed;
     
                filter: brightness(0.15);

                /* Use the same animation as the body */
                /* animation: backgroundFade 10s infinite alternate ease-in-out;  */

                /* outline for text sharpness */
                /* -webkit-text-stroke: 0.6px rgb(0, 0, 0);  */


            }
            /* animated layer for letters */
            .main-content h1::after {
                content: "AI SCOUT ENGINE"; /* Must match HTML text exactly */
                position: absolute;
                left: 0; top: 0; width: 100%; height: 100%;
                /* rgb(255, 255, 255) */
                color: transparent;
                
                -webkit-background-clip: text;
                background-clip: text;
                
                background-image: linear-gradient(135deg,rgb(255, 255, 255), rgb(255, 255, 255)), 
                                url('/images/basketball.jpeg');
                background-size: cover;
                background-position: center;
                background-attachment: fixed;
                
                animation: smoothFade 15s infinite alternate ease-in-out;
                pointer-events: none; /* Makes sure the user can still click through to the button */

                filter: brightness(4.7) contrast(1.4);
                /* -webkit-text-stroke: 0.8px rgb(255, 244, 203) */
            }
            .main-content p,a {
                font-family: 'Exo 2', sans-serif;
            }
            .main-content {
                color: rgba(255, 255, 255, 0.95);
                text-align: center;
                padding: 40px;
                /* rgba(255, 64, 0, 0.12) */
                background-color: rgba(154, 72, 45, 0.17); 
                border-radius: 12px;
                /* Adds a "floating" effect and makes glass effect better*/
                box-shadow: 0 10px 50px rgba(0, 0, 0, 0.65),
                            inset 0 0 15px rgba(255, 201, 183, 0.23); 
                border: 2px solid rgba(255, 201, 183, 0.12);
                backdrop-filter : blur(8px)
            }
            a {
                display: inline-block;
                margin-top: 20px;
                padding: 12px 24px;
                /* #620505 */
                background-color: #421515; 
                color: white;
                text-decoration: none;   
                font-weight: bold;
                border-radius: 6px;
                text-transform: uppercase;
                transition: background 0.3s; 
            }

            a:hover {
                /* #450101 */
                background-color: #220202; /* Darkens slightly when you point at it */
            }
        </style>
    </head>
    <body>
        <div style="display:none;">
            <img src="/images/stadium.jpeg">
            <img src="/images/basketball.jpeg">
        </div>
        <div class="main-content">
            <h1>AI Scout Engine</h1>
            <p>Advanced Player Analysis and Engangement Generation</p>
            
            <a href="/scout">Start Batch Scout</a>
        </div>
    </body>
</html>